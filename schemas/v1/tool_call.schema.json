{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-md-pendant/schemas/v1/tool_call.schema.json",
  "title": "tool_call",
  "type": "object",
  "required": ["v", "type", "name", "args", "status"],
  "properties": {
    "v":       {"const": 1},
    "type":    {"const": "tool_call"},
    "name":    {"type": "string"},
    "args":    {"type": "object"},
    "status":  {"enum": ["start", "ok", "error"]},
    "summary": {"type": "string"}
  },
  "additionalProperties": false
}
